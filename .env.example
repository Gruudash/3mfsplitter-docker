# 3MF Splitter -- Umgebungsvariablen
#
# Kopieren nach ".env" und nach Bedarf anpassen. docker-compose.yml liest
# diese Datei automatisch ein (env_file: .env).

# Host-Port, unter dem die App erreichbar ist (linke Seite von
# "HOST_PORT:8000"). Bei Port-Konflikten auf dem Host aendern.
HOST_PORT=8899

# Maximale Upload-Groesse einer .3mf-Datei in Megabyte. Groessere Uploads
# werden mit HTTP 413 abgelehnt.
MAX_UPLOAD_MB=200

# Erlaubte CORS-Origins, kommagetrennt (z.B. https://example.com,https://foo.bar).
# "*" erlaubt alle Origins (Standard, passend fuer lokale/private Nutzung).
CORS_ALLOW_ORIGINS=*
